# Telegram configuration
TELEGRAM_BOT_TOKEN="your_telegram_bot_token_here"

# LLM Configuration (Default is Ollama setup)
# For standard OpenAI, switch OPENAI_BASE_URL to https://api.openai.com/v1 and set OPENAI_API_KEY to your real key.
# For Docker, use http://host.docker.internal:11434/v1 instead of localhost.
OPENAI_BASE_URL="http://localhost:11434/v1"
OPENAI_API_KEY="ollama"

# Set to 'llama3', 'mistral', 'phi3' or another model you have installed in Ollama.
# For OpenAI, use 'gpt-3.5-turbo' or 'gpt-4o'.
LLM_MODEL="llama3"
VISION_MODEL="llava"
